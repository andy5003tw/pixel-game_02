# Google Apps Script 部署後的 Web App URL
# 請替換為您自己的 Google Apps Script 網址
VITE_GOOGLE_APP_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# 遊戲過關門檻 (預設 70 分)
VITE_PASS_THRESHOLD=70

# 每次遊戲抽取的題目數量 (預設 5 題)
VITE_QUESTION_COUNT=5

# 是否使用模擬資料 (true: 使用本地 mock 資料, false: 請求 Google Apps Script API)
VITE_USE_MOCK=false
